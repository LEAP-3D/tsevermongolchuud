generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. Эцэг эхийн мэдээлэл (Auth - Clerk ашиглахгүй)
model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String // Hash хийгдсэн нууц үг
  pendingPasswordHash       String?
  passwordChangeTokenHash   String?
  passwordChangeRequestedAt DateTime?
  passwordChangeExpiresAt   DateTime?
  deleteAccountTokenHash    String?
  deleteAccountRequestedAt  DateTime?
  deleteAccountExpiresAt    DateTime?
  name                      String?
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  children  Child[]
  notificationSettings NotificationSetting?
  subscriptions       UserSubscription[]
  paymentInvoices     PaymentInvoice[]
  paymentEvents       PaymentEvent[]
}

model NotificationSetting {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  emailNotifications Boolean  @default(true)
  weeklyReports      Boolean  @default(true)
  realtimeAlerts     Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 2. Хүүхдийн мэдээлэл
model Child {
  id       Int     @id @default(autoincrement())
  name     String
  pin      String?
  age      Int?
  gender   String?
  parentId Int
  parent   User    @relation(fields: [parentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alerts              Alert[]
  categorySettings    ChildCategorySetting[]
  urlSettings         ChildUrlSetting[]
  history             History[]
  dailyUsages         DailyUsage[]
  childTimeLimit      ChildTimeLimit?
  childAppLimits      ChildAppLimit[]
  childCategoryLimits ChildCategoryLimit[]
  childAlwaysAlloweds ChildAlwaysAllowed[]
  childFocusBlockeds  ChildFocusBlocked[]

  @@index([parentId])
}

// 3. Ангиллын сан (Сошиал, Тоглоом, Боловсрол г.м)
model CategoryCatalog {
  id                    Int                    @id @default(autoincrement())
  name                  String                 @unique
  childCategorySettings ChildCategorySetting[]
  dailyUsages           DailyUsage[]
}

// 4. Өдрийн хэрэглээний статистик
// 1 минут тутамд increment хийхэд энэ хүснэгт ашиглагдана.
model DailyUsage {
  id         Int             @id @default(autoincrement())
  childId    Int
  categoryId Int
  date       DateTime        @default(now()) @db.Date
  duration   Int             @default(0)
  child      Child           @relation(fields: [childId], references: [id], onDelete: Cascade)
  category   CategoryCatalog @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([childId, categoryId, date])
}

// 5. Вэбээр аялсан түүх (Reels үзэхэд Domain-оор нь багцалж хадгална)
model History {
  id           Int        @id @default(autoincrement())
  childId      Int
  fullUrl      String // Хамгийн сүүлд байсан URL (Instagram Reel URL)
  domain       String // instagram.com
  title        String?
  categoryName String
  duration     Int // Тухайн сайт дээр нийт өнгөрүүлсэн хугацаа
  visitedAt    DateTime   @default(now())
  actionTaken  StatusType
  device       String?
  child        Child      @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId, categoryName])
  @@index([childId, visitedAt])
}

// 6. Хүүхдийн тохиргоо (Ангилал болон URL-аар блоклох)
model ChildCategorySetting {
  id         Int             @id @default(autoincrement())
  childId    Int
  categoryId Int
  status     StatusType      @default(ALLOWED)
  timeLimit  Int? // Минутаар
  category   CategoryCatalog @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  child      Child           @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, categoryId])
  @@index([childId])
}

model ChildUrlSetting {
  id        Int        @id @default(autoincrement())
  childId   Int
  urlId     Int
  status    StatusType @default(ALLOWED)
  timeLimit Int?
  child     Child      @relation(fields: [childId], references: [id], onDelete: Cascade)
  urlInfo   UrlCatalog @relation(fields: [urlId], references: [id], onDelete: Cascade)

  @@unique([childId, urlId])
  @@index([childId])
}

model UrlCatalog {
  id            Int               @id @default(autoincrement())
  domain        String            @unique
  categoryName  String
  safetyScore   Int?
  tags          String[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  childSettings ChildUrlSetting[]
}

model Alert {
  id        Int       @id @default(autoincrement())
  childId   Int
  type      AlertType
  message   String
  isSent    Boolean   @default(false)
  createdAt DateTime  @default(now())
  child     Child     @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@index([childId, createdAt])
}

model ChildTimeLimit {
  id              Int      @id @default(autoincrement())
  childId         Int      @unique
  dailyLimit      Int      @default(240)
  weekdayLimit    Int      @default(180)
  weekendLimit    Int      @default(300)
  sessionLimit    Int      @default(60)
  breakEvery      Int      @default(45)
  breakDuration   Int      @default(10)
  focusMode       Boolean  @default(false)
  downtimeEnabled Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  child           Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
}

model ChildAppLimit {
  id        Int      @id @default(autoincrement())
  childId   Int
  name      String
  minutes   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, name])
  @@index([childId])
}

model ChildCategoryLimit {
  id        Int      @id @default(autoincrement())
  childId   Int
  name      String
  minutes   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, name])
  @@index([childId])
}

model ChildAlwaysAllowed {
  id        Int      @id @default(autoincrement())
  childId   Int
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, name])
  @@index([childId])
}

model ChildFocusBlocked {
  id        Int      @id @default(autoincrement())
  childId   Int
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  child     Child    @relation(fields: [childId], references: [id], onDelete: Cascade)

  @@unique([childId, name])
  @@index([childId])
}

model SubscriptionPlan {
  id             Int      @id @default(autoincrement())
  code           String   @unique
  name           String
  description    String?
  priceMnt       Int
  durationMonths Int
  maxChildren    Int
  aiAgentEnabled Boolean  @default(true)
  currency       String   @default("MNT")
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  bonumPlanId    Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  subscriptions UserSubscription[]
  invoices      PaymentInvoice[]
}

model UserSubscription {
  id                     Int                       @id @default(autoincrement())
  userId                 Int
  planId                 Int
  status                 BillingSubscriptionStatus @default(PENDING)
  source                 String?
  startsAt               DateTime?
  endsAt                 DateTime?
  activatedAt            DateTime?
  canceledAt             DateTime?
  externalSubscriptionId String?
  metadata               Json?
  latestInvoiceId        Int?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  latestInvoice PaymentInvoice? @relation("LatestInvoice", fields: [latestInvoiceId], references: [id], onDelete: SetNull)
  invoices      PaymentInvoice[] @relation("SubscriptionInvoices")

  @@index([userId, status])
  @@index([planId, status])
}

model PaymentInvoice {
  id                 Int                @id @default(autoincrement())
  userId             Int
  planId             Int
  subscriptionId     Int?
  provider           BillingProvider    @default(BONUM)
  localTransactionId String             @unique
  bonumInvoiceId     String?            @unique
  amountMnt          Int
  currency           String             @default("MNT")
  status             BillingInvoiceStatus @default(CREATED)
  followUpLink       String?
  callbackUrl        String?
  expiresAt          DateTime?
  paidAt             DateTime?
  failedAt           DateTime?
  webhookReceivedAt  DateTime?
  rawCreateResponse  Json?
  rawLastWebhook     Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                  SubscriptionPlan  @relation(fields: [planId], references: [id], onDelete: Restrict)
  subscription          UserSubscription? @relation("SubscriptionInvoices", fields: [subscriptionId], references: [id], onDelete: SetNull)
  latestForSubscriptions UserSubscription[] @relation("LatestInvoice")
  events                PaymentEvent[]

  @@index([userId, status, createdAt])
  @@index([subscriptionId])
}

model PaymentEvent {
  id             Int             @id @default(autoincrement())
  userId         Int?
  invoiceId      Int?
  provider       BillingProvider @default(BONUM)
  eventType      String
  eventStatus    String?
  dedupeKey      String          @unique
  signatureValid Boolean
  processed      Boolean         @default(false)
  processError   String?
  bonumInvoiceId String?
  transactionId  String?
  payload        Json
  headers        Json?
  receivedAt     DateTime        @default(now())
  processedAt    DateTime?

  user    User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  invoice PaymentInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([bonumInvoiceId])
  @@index([transactionId])
}

model BonumAuthToken {
  id                    Int      @id @default(autoincrement())
  terminalId            String   @unique
  accessToken           String
  refreshToken          String?
  tokenType             String?
  expiresInSeconds      Int?
  refreshExpiresSeconds Int?
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

enum StatusType {
  ALLOWED
  BLOCKED
  LIMITED
}

enum AlertType {
  DANGEROUS_CONTENT
  TIME_LIMIT_EXCEEDED
  SUSPICIOUS_ACTIVITY
}

enum BillingProvider {
  BONUM
}

enum BillingInvoiceStatus {
  CREATED
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELED
}

enum BillingSubscriptionStatus {
  PENDING
  ACTIVE
  CANCELED
  EXPIRED
  PAST_DUE
}
